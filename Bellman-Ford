class Solution {

    static int[] bellmanFord(int V, int[][] edges, int src) {

        int INF = (int)1e8;
        int[] dist = new int[V];
        Arrays.fill(dist, INF);

        dist[src] = 0;

        // Relax all edges V-1 times
        for (int i = 1; i < V; i++) {

            boolean updated = false;

            for (int[] edge : edges) {

                int u = edge[0];
                int v = edge[1];
                int w = edge[2];

                if (dist[u] != INF && dist[u] + w < dist[v]) {
                    dist[v] = dist[u] + w;
                    updated = true;
                }
            }

            if (!updated) {
                break;
            }
        }

        // Check for negative weight cycle
        for (int[] edge : edges) {

            int u = edge[0];
            int v = edge[1];
            int w = edge[2];

            if (dist[u] != INF && dist[u] + w < dist[v]) {
                return new int[]{-1};
            }
        }

        return dist;
    }
}
